---
const currentYear = new Date().getFullYear();

const services = [
  {
    title: 'Architecture & Infrastructure Advisory',
    intro:
      'For companies whose AWS bill is scary, deployments take hours, or “we’ll fix it later” became the architecture.',
    outcome:
      'Architecture audits, migration roadmaps, infrastructure-as-code implementation, and pragmatic cost optimization.',
    engagement: 'Typical engagement: 4-8 week project or ongoing advisory retainer.',
    image: '/images/services/architecture.png',
  },
  {
    title: 'Fractional Engineering Leadership',
    intro:
      'For companies that need CTO/VPE-level judgment before a full-time executive hire makes sense.',
    outcome:
      'Technical strategy, team structure, hiring support, engineering process, incident response, and stakeholder communication.',
    engagement: 'Typical engagement: 10-20 hours/week, 3-6 month minimum.',
    image: '/images/services/leadership.png',
  },
  {
    title: 'Team & Process Transformation',
    intro:
      'For teams shipping slowly, fighting fires, or scaling faster than their development habits can handle.',
    outcome:
      'CI/CD buildout, testing strategy, developer experience improvements, and onboarding that does not take weeks.',
    engagement: 'Typical engagement: 6-12 week intensive.',
    image: '/images/services/operations.png',
  },
];

const results = [
  {
    metric: '99.67%',
    label: 'search performance',
    text:
      'Rebuilt healthcare RFP search so enterprise users could get near-instant results instead of waiting on slow queries.',
  },
  {
    metric: '100x',
    label: 'message throughput',
    text:
      'Refactored the core messaging pipeline behind 4-5 million monthly messages, removing the bottleneck and restoring operating headroom.',
  },
  {
    metric: '0 downtime',
    label: 'infrastructure migration',
    text:
      'Led the move from colocated infrastructure to AWS EKS with Terraform automation while keeping the customer experience stable.',
  },
];

const technologies = ['Go', 'Python', 'AWS', 'EKS', 'Terraform', 'Docker', 'Kubernetes', 'Postgres', 'Kafka', 'CI/CD', 'TypeScript', 'React'];
---

