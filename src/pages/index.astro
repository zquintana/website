              <h1>Systems and delivery built for growth.</h1>
              <div class="hero-actions">
                <a class="button primary hero-primary" href="#services">See how I work</a>
                <a class="button secondary" href="https://calendly.com/zach-quintana/30min" target="_blank" rel="noopener noreferrer">Book a call</a>
              </div>
            </div>
          </div>
          <div class="hero-proof" aria-label="Consulting focus areas">
            <span class="is-active" data-hero-pill>Scale bottlenecks</span>
            <span data-hero-pill>AWS migrations</span>
            <span data-hero-pill>AI workflows</span>
            <span data-hero-pill>Team velocity</span>
          </div>
        </div>
      </section>

      <section class="trust section reveal" aria-label="Previous companies">
        <p>Previously at and trusted inside</p>
        <div class="company-strip">
          <span>Proposal Technologies</span>
          <span>Wolfe / GiftYa</span>
          <span>Zingle</span>
          <span>Medallia</span>
          <span>CBS Interactive</span>
        </div>
      </section>

      <section class="section split-heading reveal" id="services">
        <div>
          <p class="section-kicker">
            <span class="section-mark" aria-hidden="true"><span></span><span></span><span></span></span>
            Services
          </p>
          <h2>Senior technical help when the problem is bigger than another sprint ticket.</h2>
        </div>
        <p>
          I work best where architecture, infrastructure, delivery, and engineering leadership overlap. The work is hands-on enough to unblock the team and strategic enough to make the next decision easier.
        </p>
      </section>

      <section class="cards services-grid section-tight" aria-label="Consulting services">
        {services.map((service) => (
          <article class="card service-card reveal">
            <div class="card-art" aria-hidden="true">
              <img src={service.image} alt="" loading="lazy" />
            </div>
