    />
    <meta property="og:title" content="Zach Quintana | Fractional Engineering Leadership" />
    <meta
      property="og:description"
      content="Architecture advisory, cloud migration, and team transformation for growth-stage companies."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://zachquintana.com/" />
    <meta property="og:image" content="https://zachquintana.com/images/profile.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="/favicon.png" />
  </head>
  <body>
    <nav class="site-nav" aria-label="Primary navigation">
      <a class="brand" href="#top" aria-label="Zach Quintana home"><span>ZQ</span><small>Zach Quintana</small></a>
      <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="nav-links">
        <span class="sr-only">Toggle navigation</span>
        <span></span>
        <span></span>
      </button>
      <div class="nav-links" id="nav-links">
        <a href="#top">Home</a>
        <a href="#services">Services</a>
        <a href="#results">Results</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
        <button class="theme-toggle" type="button" aria-label="Toggle theme">
          <svg class="icon icon-sun" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 4V2m0 20v-2m8-8h2M2 12h2m13.66-5.66 1.42-1.42M4.92 19.08l1.42-1.42m11.32 0 1.42 1.42M4.92 4.92l1.42 1.42" />
